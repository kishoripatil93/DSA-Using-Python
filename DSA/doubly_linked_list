class DLL:
    def __init__(self, head = None):
        self.head = head

    def is_empty(self):
        return self.head == None
    
    def add_to_head(self, item):
        n = Node(None, item, self.head)

        if not self.is_empty():
            self.head.prev = n    
        self.head = n

    def add_to_tail(self, item):
        if self.is_empty():
            n = Node(None, item, None)
            self.head = n
        else:
            temp = self.head
            while temp.next is not None:
                temp = temp.next

            n = Node(temp, item, None)
            temp.next = n

    def search_elt(self, elt):
        temp = self.head
        while temp is not None:
            if elt == temp.item:
                print(temp.item, " is present in the list")
                return temp
            temp = temp.next

        print(elt, " is not present in the list")
        return None
    
    def insert_in_between(self, node, item):
        if node is not None:
            n = Node(node, item, node.next)
            if node.next is not None:
                node.next.prev = n
            node.next = n

